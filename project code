import zipfile

with zipfile.ZipFile('/content/facebook.zip', 'r') as zip_ref:
    zip_ref.extractall('/content/facebook')
import cv2
import numpy as np
import os
import json
from tqdm import tqdm
from skimage.feature import hog, local_binary_pattern
from skimage.metrics import structural_similarity as ssim
from sklearn.metrics.pairwise import cosine_similarity
import matplotlib.pyplot as plt

print("All libraries imported successfully!")
class PhishingImageAnalyzer:
    def __init__(self, dataset_path, output_dir='./results'):
        self.dataset_path = dataset_path
        self.output_dir = output_dir
        os.makedirs(output_dir, exist_ok=True)
        self.results = {
            'structural_similarity': {},
            'feature_matching': {},
            'color_histograms': {},
            'texture_analysis': {}
        }

    def _preprocess_image(self, img):
        """Enhanced preprocessing pipeline"""
        # Standardize size
        img = cv2.resize(img, (800, 600))

        # Denoising
        img = cv2.fastNlMeansDenoisingColored(img, None, 10, 10, 7, 21)

        # Contrast enhancement
        lab = cv2.cvtColor(img, cv2.COLOR_RGB2LAB)
        l, a, b = cv2.split(lab)
        clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8,8))
        img = cv2.merge([clahe.apply(l), a, b])
        enhanced = cv2.cvtColor(img, cv2.COLOR_LAB2RGB)

        return enhanced
def process_folder(self, folder_name):
    """Process all images in a subfolder"""
    folder_path = os.path.join(self.dataset_path, folder_name)
    image_files = [f for f in os.listdir(folder_path) if f.lower().endswith(('png', 'jpg', 'jpeg'))]

    if not image_files:
        print(f"No images found in {folder_path}")
        return None

    print(f"\nProcessing {len(image_files)} images in {folder_name}...")

    # Process all images in the folder
    processed_images = []
    for img_file in tqdm(image_files, desc=f"Processing {folder_name}"):
        img_path = os.path.join(folder_path, img_file)
        try:
            # Load and preprocess image
            img = cv2.imread(img_path)
            if img is None:
                continue
            img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
            processed = self._preprocess_image(img)
            processed_images.append((img_file, processed))
        except Exception as e:
            print(f"Error processing {img_file}: {str(e)}")
            continue

    return processed_images

# Add the method to the class
PhishingImageAnalyzer.process_folder = process_folder
def extract_features(self, img):
    """Extract multiple feature types from Unit IV"""
    gray = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)

    # 1. ORB Features (Unit IV)
    orb = cv2.ORB_create(nfeatures=500)
    kp_orb, des_orb = orb.detectAndCompute(gray, None)

    # 2. HOG Features (Unit IV)
    hog_features, hog_image = hog(gray, orientations=8, pixels_per_cell=(16, 16),
                                  cells_per_block=(1, 1), visualize=True)

    # 3. LBP Texture (Advanced texture analysis)
    lbp = local_binary_pattern(gray, P=8, R=1, method="uniform")

    # 4. Color Histogram (Unit V)
    hist = cv2.calcHist([img], [0, 1, 2], None, [8, 8, 8], [0, 256, 0, 256, 0, 256])
    hist = cv2.normalize(hist, hist).flatten()

    return {
        'orb': (kp_orb, des_orb),
        'hog': (hog_features, hog_image),
        'lbp': lbp,
        'color_hist': hist
    }

# Add the method to the class
PhishingImageAnalyzer.extract_features = extract_features
def compare_images(self, img1, img2, features1, features2):
    """Compare images using multiple methods"""

    # 1. Structural Similarity (SSIM)
    gray1 = cv2.cvtColor(img1, cv2.COLOR_RGB2GRAY)
    gray2 = cv2.cvtColor(img2, cv2.COLOR_RGB2GRAY)
    ssim_score, _ = ssim(gray1, gray2, full=True)

    # 2. Feature Matching (ORB)
    bf = cv2.BFMatcher(cv2.NORM_HAMMING, crossCheck=True)
    if features1['orb'][1] is not None and features2['orb'][1] is not None:
        matches = bf.match(features1['orb'][1], features2['orb'][1])
        match_score = len(matches) / max(len(features1['orb'][0]), len(features2['orb'][0])) if (features1['orb'][0] is not None and features2['orb'][0] is not None) else 0
    else:
        match_score = 0

    # 3. Color Histogram Comparison
    hist_score = cv2.compareHist(features1['color_hist'], features2['color_hist'], cv2.HISTCMP_CORREL)

    # 4. HOG Feature Similarity
    hog_score = cosine_similarity(features1['hog'][0].reshape(1, -1), features2['hog'][0].reshape(1, -1))[0][0]

    return {
        'ssim': ssim_score,
        'feature_matches': match_score,
        'color_similarity': hist_score,
        'hog_similarity': hog_score
    }

# Add the method to the class
PhishingImageAnalyzer.compare_images = compare_images
def analyze_folder(self, folder_name):
    """Complete analysis pipeline for a folder"""
    processed_images = self.process_folder(folder_name)

    if not processed_images:
        return

    # Extract features for all images
    features = {}
    print("\nExtracting features...")
    for img_file, img in tqdm(processed_images, desc="Feature extraction"):
        features[img_file] = self.extract_features(img)

    # Compare all image pairs
    print("\nComparing images...")
    img_files = [img[0] for img in processed_images]

    for i in tqdm(range(len(img_files)), desc="Pairwise comparison"):
        for j in range(i+1, len(img_files)):
            file1, file2 = img_files[i], img_files[j]
            img1 = processed_images[i][1]
            img2 = processed_images[j][1]
            comparison = self.compare_images(img1, img2, features[file1], features[file2])

            # Store results
            pair_key = f"{file1}_{file2}"
            self.results['structural_similarity'][pair_key] = comparison['ssim']
            self.results['feature_matching'][pair_key] = comparison['feature_matches']
            self.results['color_histograms'][pair_key] = comparison['color_similarity']
            self.results['texture_analysis'][pair_key] = comparison['hog_similarity']

    # Save results
    self.save_results(folder_name)
    self.visualize_features(processed_images[0][1], features[img_files[0]])

# Add the method to the class
PhishingImageAnalyzer.analyze_folder = analyze_folder
def save_results(self, folder_name):
    """Save analysis results to JSON"""
    output_file = os.path.join(self.output_dir, f"{folder_name}_analysis.json")
    with open(output_file, 'w') as f:
        json.dump(self.results, f, indent=2)
    print(f"\nResults saved to {output_file}")

def visualize_features(self, img, features):
    """Visualize extracted features"""
    plt.figure(figsize=(15,10))

    # Original Image
    plt.subplot(2, 3, 1)
    plt.imshow(img)
    plt.title('Original Image')
    plt.axis('off')

    # ORB Features
    if features['orb'][0] is not None:
        img_orb = cv2.drawKeypoints(img, features['orb'][0], None, color=(0, 255, 0), flags=0)
        plt.subplot(2, 3, 2)
        plt.imshow(img_orb)
        plt.title('ORB Features')
        plt.axis('off')

    # HOG Features
    plt.subplot(2, 3, 3)
    plt.imshow(features['hog'][1], cmap='gray')
    plt.title('HOG Visualization')
    plt.axis('off')

    # LBP Texture
    plt.subplot(2, 3, 4)
    plt.imshow(features['lbp'], cmap='gray')
    plt.title('LBP Texture')
    plt.axis('off')

    # Color Histogram
    plt.subplot(2, 3, 5)
    plt.plot(features['color_hist'])
    plt.title('Color Histogram')
    plt.xlabel('Bin')
    plt.ylabel('Frequency')

    plt.tight_layout()
    plt.savefig(os.path.join(self.output_dir, 'feature_visualization.png'))
    plt.show()
    plt.close()

# Add the methods to the class
PhishingImageAnalyzer.save_results = save_results
PhishingImageAnalyzer.visualize_features = visualize_features
